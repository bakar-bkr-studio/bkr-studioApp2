# Variables d'environnement — BKR Studio App
# Copier ce fichier en .env.local et remplir les valeurs
# .env.local est dans .gitignore → jamais commité (règle SECURITY.md)

# ------- Firebase App + Firebase Authentication (email/password) -------
# Valeurs à récupérer dans Firebase Console > Project settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ------- Firebase Admin SDK (serveur uniquement) -------
# À récupérer dans Firebase Console > Project settings > Service accounts
# IMPORTANT: FIREBASE_PRIVATE_KEY doit conserver les "\n" (ou être entourée de guillemets)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ------- Sécurité API -------
# Liste d'origines autorisées en plus de l'origine principale de l'app (séparées par des virgules)
# Exemple: ALLOWED_ORIGINS=https://bkrstudio.app,https://staging.bkrstudio.app
ALLOWED_ORIGINS=
